PORT=3011
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/payments_db?retryWrites=true&w=majority

# Clave secreta para verificar tokens JWT (debe coincidir con la que emite el API Gateway / Auth service)
JWT_SECRET=change_me_in_production

# URL base del microservicio de órdenes (sin slash final)
# Si no se define, la validación de orderId usa verificación local básica (solo en desarrollo)
ORDERS_SERVICE_URL=http://orders-service:3000
REDIS_URL=redis://localhost:6379
